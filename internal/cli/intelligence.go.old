// Package cli provides CLI commands for the intelligence system
package cli

import (
	"context"
	"fmt"
	"strconv"
	"strings"
	"time"

	"github.com/spf13/cobra"
	"nix-ai-help/internal/intelligence"
	"nix-ai-help/pkg/utils"
)

// addIntelligenceCommands adds intelligence-related commands to the CLI
func (c *CLI) addIntelligenceCommands() {
	// Main intelligence command
	intelligenceCmd := &cobra.Command{
		Use:   "intelligence",
		Short: "AI-powered system intelligence and recommendations",
		Long: `The intelligence command provides AI-powered analysis, predictions, and recommendations
for your NixOS system. It includes system analysis, conflict detection, dependency analysis,
and smart recommendations based on your usage patterns.`,
		Aliases: []string{"intel", "ai"},
		Example: `  # Get comprehensive system intelligence
  nixai intelligence analyze

  # Get predictive suggestions
  nixai intelligence predict

  # Detect configuration conflicts
  nixai intelligence conflicts

  # Analyze dependencies
  nixai intelligence dependencies

  # Get smart recommendations
  nixai intelligence recommend`,
	}

	// Add subcommands
	intelligenceCmd.AddCommand(c.createAnalyzeCommand())
	intelligenceCmd.AddCommand(c.createPredictCommand())
	intelligenceCmd.AddCommand(c.createConflictsCommand())
	intelligenceCmd.AddCommand(c.createDependenciesCommand())
	intelligenceCmd.AddCommand(c.createRecommendCommand())
	intelligenceCmd.AddCommand(c.createIntelligenceStatusCommand())

	c.rootCmd.AddCommand(intelligenceCmd)
}

// createAnalyzeCommand creates the system analysis command
func (c *CLI) createAnalyzeCommand() *cobra.Command {
	var detailed bool
	var format string
	var output string

	cmd := &cobra.Command{
		Use:   "analyze",
		Short: "Perform comprehensive system analysis",
		Long: `Analyzes your NixOS system comprehensively, including:
- Installed packages and their metadata
- Running services and their configurations
- Hardware capabilities and utilization
- Security settings and vulnerabilities
- Performance metrics and bottlenecks
- System modules and configurations`,
		Example: `  # Basic system analysis
  nixai intelligence analyze

  # Detailed analysis with JSON output
  nixai intelligence analyze --detailed --format json

  # Save analysis to file
  nixai intelligence analyze --output system-analysis.json`,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := context.Background()
			
			// Initialize intelligence components
			analyzer := intelligence.NewSystemAnalyzer(c.logger, c.config)
			
			// Perform analysis
			analysis, err := analyzer.AnalyzeSystem(ctx, c.config)
			if err != nil {
				return fmt.Errorf("system analysis failed: %w", err)
			}

			// Format and display results
			return c.displaySystemAnalysis(analysis, detailed, format, output)
		},
	}

	cmd.Flags().BoolVarP(&detailed, "detailed", "d", false, "Show detailed analysis")
	cmd.Flags().StringVarP(&format, "format", "f", "text", "Output format (text, json, yaml)")
	cmd.Flags().StringVarP(&output, "output", "o", "", "Output file path")

	return cmd
}

// createPredictCommand creates the predictive suggestions command
func (c *CLI) createPredictCommand() *cobra.Command {
	var category string
	var confidence float64
	var limit int

	cmd := &cobra.Command{
		Use:   "predict",
		Short: "Generate AI-powered predictive suggestions",
		Long: `Generates predictive suggestions based on your system state and usage patterns:
- Package installation suggestions
- Configuration optimizations
- Security improvements
- Performance enhancements
- Maintenance recommendations`,
		Example: `  # Get all predictions
  nixai intelligence predict

  # Get only package suggestions
  nixai intelligence predict --category packages

  # Filter by confidence level
  nixai intelligence predict --confidence 0.8

  # Limit number of suggestions
  nixai intelligence predict --limit 10`,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := context.Background()
			
			// Initialize intelligence components
			analyzer := intelligence.NewSystemAnalyzer(c.logger, c.config)
			predictor := intelligence.NewPredictor(c.logger, c.aiProvider, analyzer)
			
			// Generate predictions
			predictions, err := predictor.GeneratePredictions(ctx, c.config)
			if err != nil {
				return fmt.Errorf("prediction generation failed: %w", err)
			}

			// Filter and display results
			return c.displayPredictions(predictions, category, confidence, limit)
		},
	}

	cmd.Flags().StringVarP(&category, "category", "c", "", "Filter by category (packages, config, security, performance, maintenance)")
	cmd.Flags().Float64VarP(&confidence, "confidence", "", 0.0, "Minimum confidence level (0.0-1.0)")
	cmd.Flags().IntVarP(&limit, "limit", "l", 0, "Maximum number of suggestions")

	return cmd
}

// createConflictsCommand creates the conflict detection command
func (c *CLI) createConflictsCommand() *cobra.Command {
	var severity string
	var autoFix bool
	var dryRun bool

	cmd := &cobra.Command{
		Use:   "conflicts",
		Short: "Detect and resolve system conflicts",
		Long: `Detects various types of conflicts in your NixOS system:
- Package conflicts and incompatibilities
- Service port conflicts
- Configuration conflicts
- Resource conflicts
- Dependency conflicts`,
		Example: `  # Detect all conflicts
  nixai intelligence conflicts

  # Show only high-severity conflicts
  nixai intelligence conflicts --severity high

  # Show what would be fixed (dry run)
  nixai intelligence conflicts --auto-fix --dry-run

  # Automatically fix resolvable conflicts
  nixai intelligence conflicts --auto-fix`,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := context.Background()
			
			// Initialize intelligence components
			analyzer := intelligence.NewSystemAnalyzer(c.logger, c.config)
			conflictDetector := intelligence.NewConflictDetector(c.logger, analyzer)
			
			// Detect conflicts
			conflicts, err := conflictDetector.DetectConflicts(ctx, c.config)
			if err != nil {
				return fmt.Errorf("conflict detection failed: %w", err)
			}

			// Display results
			return c.displayConflicts(conflicts, severity, autoFix, dryRun)
		},
	}

	cmd.Flags().StringVarP(&severity, "severity", "s", "", "Filter by severity (critical, high, medium, low)")
	cmd.Flags().BoolVarP(&autoFix, "auto-fix", "a", false, "Automatically fix resolvable conflicts")
	cmd.Flags().BoolVarP(&dryRun, "dry-run", "n", false, "Show what would be done without making changes")

	return cmd
}

// createDependenciesCommand creates the dependency analysis command
func (c *CLI) createDependenciesCommand() *cobra.Command {
	var showGraph bool
	var package string
	var depth int
	var format string

	cmd := &cobra.Command{
		Use:   "dependencies",
		Short: "Analyze system dependencies and relationships",
		Long: `Analyzes dependency relationships in your NixOS system:
- Package dependencies and dependents
- Service dependencies
- Circular dependency detection
- Critical path analysis
- Orphaned package detection`,
		Example: `  # Analyze all dependencies
  nixai intelligence dependencies

  # Show dependency graph
  nixai intelligence dependencies --graph

  # Analyze specific package
  nixai intelligence dependencies --package git

  # Limit dependency depth
  nixai intelligence dependencies --depth 3`,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := context.Background()
			
			// Initialize intelligence components
			analyzer := intelligence.NewSystemAnalyzer(c.logger, c.config)
			dependencyAnalyzer := intelligence.NewDependencyAnalyzer(c.logger, analyzer)
			
			// Analyze dependencies
			dependencies, err := dependencyAnalyzer.AnalyzeDependencies(ctx, c.config)
			if err != nil {
				return fmt.Errorf("dependency analysis failed: %w", err)
			}

			// Display results
			return c.displayDependencies(dependencies, showGraph, package, depth, format)
		},
	}

	cmd.Flags().BoolVarP(&showGraph, "graph", "g", false, "Show dependency graph visualization")
	cmd.Flags().StringVarP(&package, "package", "p", "", "Focus on specific package")
	cmd.Flags().IntVarP(&depth, "depth", "d", 0, "Maximum dependency depth to show")
	cmd.Flags().StringVarP(&format, "format", "f", "text", "Output format (text, json, dot)")

	return cmd
}

// createRecommendCommand creates the recommendations command
func (c *CLI) createRecommendCommand() *cobra.Command {
	var category string
	var priority string
	var interactive bool
	var apply bool

	cmd := &cobra.Command{
		Use:   "recommend",
		Short: "Get AI-powered system recommendations",
		Long: `Generates comprehensive recommendations based on all available intelligence:
- System optimizations
- Security improvements
- Performance enhancements
- Configuration suggestions
- User-specific recommendations
- Workflow optimizations`,
		Example: `  # Get all recommendations
  nixai intelligence recommend

  # Get only security recommendations
  nixai intelligence recommend --category security

  # Get only high-priority recommendations
  nixai intelligence recommend --priority high

  # Interactive recommendation review
  nixai intelligence recommend --interactive

  # Apply recommended changes
  nixai intelligence recommend --apply`,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := context.Background()
			
			// Initialize all intelligence components
			analyzer := intelligence.NewSystemAnalyzer(c.logger, c.config)
			predictor := intelligence.NewPredictor(c.logger, c.aiProvider, analyzer)
			conflictDetector := intelligence.NewConflictDetector(c.logger, analyzer)
			dependencyAnalyzer := intelligence.NewDependencyAnalyzer(c.logger, analyzer)
			recommendationsEngine := intelligence.NewRecommendationsEngine(
				c.logger, c.aiProvider, analyzer, predictor, conflictDetector, dependencyAnalyzer)
			
			// Generate recommendations
			recommendations, err := recommendationsEngine.GenerateRecommendations(ctx, c.config)
			if err != nil {
				return fmt.Errorf("recommendation generation failed: %w", err)
			}

			// Display and potentially apply recommendations
			return c.displayRecommendations(recommendations, category, priority, interactive, apply)
		},
	}

	cmd.Flags().StringVarP(&category, "category", "c", "", "Filter by category (optimization, security, performance, maintenance, configuration, user, workflow, environment)")
	cmd.Flags().StringVarP(&priority, "priority", "p", "", "Filter by priority (critical, high, medium, low)")
	cmd.Flags().BoolVarP(&interactive, "interactive", "i", false, "Interactive recommendation review")
	cmd.Flags().BoolVarP(&apply, "apply", "a", false, "Apply recommended changes")

	return cmd
}

// createIntelligenceStatusCommand creates the intelligence status command
func (c *CLI) createIntelligenceStatusCommand() *cobra.Command {
	var clearCache bool

	cmd := &cobra.Command{
		Use:   "status",
		Short: "Show intelligence system status and metrics",
		Long: `Shows the current status of the intelligence system:
- Analysis cache status
- Recent predictions
- System health metrics
- Intelligence component status`,
		Example: `  # Show intelligence status
  nixai intelligence status

  # Clear intelligence cache
  nixai intelligence status --clear-cache`,
		RunE: func(cmd *cobra.Command, args []string) error {
			if clearCache {
				return c.clearIntelligenceCache()
			}
			return c.displayIntelligenceStatus()
		},
	}

	cmd.Flags().BoolVarP(&clearCache, "clear-cache", "c", false, "Clear intelligence cache")

	return cmd
}

// Display methods for intelligence results

func (c *CLI) displaySystemAnalysis(analysis *intelligence.SystemAnalysis, detailed bool, format, output string) error {
	switch format {
	case "json":
		return c.outputJSON(analysis, output)
	case "yaml":
		return c.outputYAML(analysis, output)
	default:
		return c.displaySystemAnalysisText(analysis, detailed, output)
	}
}

func (c *CLI) displaySystemAnalysisText(analysis *intelligence.SystemAnalysis, detailed bool, output string) error {
	var content strings.Builder

	// Header
	content.WriteString(utils.FormatHeader("System Analysis Report"))
	content.WriteString(fmt.Sprintf("Generated: %s\n", time.Now().Format("2006-01-02 15:04:05")))
	content.WriteString(fmt.Sprintf("System: %s (%s)\n", analysis.Hostname, analysis.SystemType))
	content.WriteString(utils.FormatDivider())

	// Summary
	content.WriteString(utils.FormatSubHeader("Summary"))
	content.WriteString(utils.FormatKeyValue("NixOS Version", analysis.NixOSVersion))
	content.WriteString(utils.FormatKeyValue("Installed Packages", strconv.Itoa(len(analysis.InstalledPackages))))
	content.WriteString(utils.FormatKeyValue("Enabled Services", strconv.Itoa(len(analysis.EnabledServices))))
	content.WriteString(utils.FormatKeyValue("Security Score", fmt.Sprintf("%.1f/100", analysis.SecuritySettings.SecurityScore)))
	content.WriteString(utils.FormatKeyValue("Boot Time", analysis.PerformanceMetrics.BootTime.String()))
	content.WriteString(utils.FormatKeyValue("Memory Usage", fmt.Sprintf("%.1f%%", analysis.PerformanceMetrics.MemoryUsage)))

	if detailed {
		// Detailed sections
		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Hardware Information"))
		content.WriteString(utils.FormatKeyValue("CPU", analysis.HardwareInfo.CPU.Model))
		content.WriteString(utils.FormatKeyValue("Memory", fmt.Sprintf("%.1f GB", float64(analysis.HardwareInfo.Memory.Total)/(1024*1024*1024))))
		content.WriteString(utils.FormatKeyValue("Architecture", analysis.HardwareInfo.Architecture))

		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Top Packages by Size"))
		// Sort packages by size and show top 10
		packages := make([]intelligence.PackageInfo, len(analysis.InstalledPackages))
		copy(packages, analysis.InstalledPackages)
		
		// Simple sort by size (descending)
		for i := 0; i < len(packages)-1; i++ {
			for j := i + 1; j < len(packages); j++ {
				if packages[i].Size < packages[j].Size {
					packages[i], packages[j] = packages[j], packages[i]
				}
			}
		}
		
		limit := 10
		if len(packages) < limit {
			limit = len(packages)
		}
		
		for i := 0; i < limit; i++ {
			pkg := packages[i]
			size := fmt.Sprintf("%.1f MB", float64(pkg.Size)/(1024*1024))
			content.WriteString(utils.FormatKeyValue(pkg.Name, size))
		}

		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Security Issues"))
		vulnerableCount := 0
		for _, pkg := range analysis.InstalledPackages {
			if pkg.Security.HasVulnerabilities {
				vulnerableCount++
			}
		}
		content.WriteString(utils.FormatKeyValue("Vulnerable Packages", strconv.Itoa(vulnerableCount)))
		content.WriteString(utils.FormatKeyValue("Firewall Enabled", strconv.FormatBool(analysis.SecuritySettings.FirewallEnabled)))
		content.WriteString(utils.FormatKeyValue("Full Disk Encryption", strconv.FormatBool(analysis.SecuritySettings.EncryptionStatus.FullDiskEncryption)))
	}

	if output != "" {
		return c.writeToFile(content.String(), output)
	}

	fmt.Print(content.String())
	return nil
}

func (c *CLI) displayPredictions(predictions *intelligence.PredictionResult, category string, confidence float64, limit int) error {
	var content strings.Builder

	content.WriteString(utils.FormatHeader("Predictive Suggestions"))
	content.WriteString(fmt.Sprintf("Generated: %s\n", predictions.GeneratedAt.Format("2006-01-02 15:04:05")))
	content.WriteString(fmt.Sprintf("Overall Confidence: %.1f%%\n", predictions.Confidence*100))
	content.WriteString(fmt.Sprintf("Model: %s\n", predictions.ModelUsed))
	content.WriteString(utils.FormatDivider())

	// Filter and display suggestions based on parameters
	if category == "" || category == "packages" {
		content.WriteString(c.formatPackageSuggestions(predictions.PackageSuggestions, confidence, limit))
	}
	if category == "" || category == "config" {
		content.WriteString(c.formatConfigSuggestions(predictions.ConfigSuggestions, confidence, limit))
	}
	if category == "" || category == "security" {
		content.WriteString(c.formatSecuritySuggestions(predictions.SecuritySuggestions, confidence, limit))
	}
	if category == "" || category == "performance" {
		content.WriteString(c.formatPerformanceSuggestions(predictions.PerformanceSuggestions, confidence, limit))
	}
	if category == "" || category == "maintenance" {
		content.WriteString(c.formatMaintenanceSuggestions(predictions.MaintenanceSuggestions, confidence, limit))
	}

	// Show reasoning chain
	if len(predictions.ReasoningChain) > 0 {
		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("AI Reasoning"))
		for _, step := range predictions.ReasoningChain {
			content.WriteString(fmt.Sprintf("Step %d: %s\n", step.Step, step.Description))
			content.WriteString(fmt.Sprintf("  Confidence: %.1f%%\n", step.Confidence*100))
			content.WriteString(fmt.Sprintf("  Conclusion: %s\n", step.Conclusion))
		}
	}

	fmt.Print(content.String())
	return nil
}

func (c *CLI) formatPackageSuggestions(suggestions []intelligence.PackageSuggestion, confidence float64, limit int) string {
	var content strings.Builder
	
	if len(suggestions) == 0 {
		return ""
	}

	content.WriteString(utils.FormatSubHeader("Package Suggestions"))
	
	count := 0
	for _, suggestion := range suggestions {
		if confidence > 0 && suggestion.Confidence < confidence {
			continue
		}
		if limit > 0 && count >= limit {
			break
		}

		content.WriteString(fmt.Sprintf("📦 %s (%s priority)\n", suggestion.PackageName, suggestion.Priority))
		content.WriteString(fmt.Sprintf("   %s\n", suggestion.Reason))
		content.WriteString(fmt.Sprintf("   Confidence: %.1f%% | Category: %s\n", suggestion.Confidence*100, suggestion.Category))
		if suggestion.InstallCommand != "" {
			content.WriteString(fmt.Sprintf("   Install: %s\n", suggestion.InstallCommand))
		}
		content.WriteString("\n")
		count++
	}

	return content.String()
}

func (c *CLI) formatConfigSuggestions(suggestions []intelligence.ConfigSuggestion, confidence float64, limit int) string {
	var content strings.Builder
	
	if len(suggestions) == 0 {
		return ""
	}

	content.WriteString(utils.FormatSubHeader("Configuration Suggestions"))
	
	count := 0
	for _, suggestion := range suggestions {
		if confidence > 0 && suggestion.Confidence < confidence {
			continue
		}
		if limit > 0 && count >= limit {
			break
		}

		content.WriteString(fmt.Sprintf("⚙️  %s.%s (%s priority)\n", suggestion.ModuleName, suggestion.Option, suggestion.Priority))
		content.WriteString(fmt.Sprintf("   %s\n", suggestion.Reason))
		content.WriteString(fmt.Sprintf("   Current: %v → Suggested: %v\n", suggestion.CurrentValue, suggestion.SuggestedValue))
		content.WriteString(fmt.Sprintf("   Confidence: %.1f%% | Impact: %s\n", suggestion.Confidence*100, suggestion.Impact))
		if suggestion.Example != "" {
			content.WriteString(fmt.Sprintf("   Example: %s\n", suggestion.Example))
		}
		content.WriteString("\n")
		count++
	}

	return content.String()
}

func (c *CLI) formatSecuritySuggestions(suggestions []intelligence.SecuritySuggestion, confidence float64, limit int) string {
	var content strings.Builder
	
	if len(suggestions) == 0 {
		return ""
	}

	content.WriteString(utils.FormatSubHeader("Security Suggestions"))
	
	count := 0
	for _, suggestion := range suggestions {
		if confidence > 0 && suggestion.Confidence < confidence {
			continue
		}
		if limit > 0 && count >= limit {
			break
		}

		severityIcon := "🔒"
		switch suggestion.Severity {
		case "critical":
			severityIcon = "🚨"
		case "high":
			severityIcon = "⚠️"
		case "medium":
			severityIcon = "⚡"
		}

		content.WriteString(fmt.Sprintf("%s %s (%s severity)\n", severityIcon, suggestion.Title, suggestion.Severity))
		content.WriteString(fmt.Sprintf("   %s\n", suggestion.Description))
		content.WriteString(fmt.Sprintf("   Confidence: %.1f%% | Category: %s\n", suggestion.Confidence*100, suggestion.Category))
		content.WriteString(fmt.Sprintf("   Action: %s\n", suggestion.RecommendedAction))
		content.WriteString("\n")
		count++
	}

	return content.String()
}

func (c *CLI) formatPerformanceSuggestions(suggestions []intelligence.PerformanceSuggestion, confidence float64, limit int) string {
	var content strings.Builder
	
	if len(suggestions) == 0 {
		return ""
	}

	content.WriteString(utils.FormatSubHeader("Performance Suggestions"))
	
	count := 0
	for _, suggestion := range suggestions {
		if confidence > 0 && suggestion.Confidence < confidence {
			continue
		}
		if limit > 0 && count >= limit {
			break
		}

		content.WriteString(fmt.Sprintf("🚀 %s Optimization (%s priority)\n", strings.Title(suggestion.Component), suggestion.Priority))
		content.WriteString(fmt.Sprintf("   Issue: %s\n", suggestion.Issue))
		content.WriteString(fmt.Sprintf("   Suggestion: %s\n", suggestion.Suggestion))
		content.WriteString(fmt.Sprintf("   Expected Gain: %s\n", suggestion.ExpectedGain))
		content.WriteString(fmt.Sprintf("   Confidence: %.1f%% | Complexity: %s\n", suggestion.Confidence*100, suggestion.Complexity))
		content.WriteString("\n")
		count++
	}

	return content.String()
}

func (c *CLI) formatMaintenanceSuggestions(suggestions []intelligence.MaintenanceSuggestion, confidence float64, limit int) string {
	var content strings.Builder
	
	if len(suggestions) == 0 {
		return ""
	}

	content.WriteString(utils.FormatSubHeader("Maintenance Suggestions"))
	
	count := 0
	for _, suggestion := range suggestions {
		if confidence > 0 && suggestion.Confidence < confidence {
			continue
		}
		if limit > 0 && count >= limit {
			break
		}

		content.WriteString(fmt.Sprintf("🔧 %s (%s priority)\n", suggestion.Task, suggestion.Priority))
		content.WriteString(fmt.Sprintf("   %s\n", suggestion.Description))
		content.WriteString(fmt.Sprintf("   Frequency: %s | Next Due: %s\n", suggestion.Frequency, suggestion.NextDue.Format("2006-01-02")))
		content.WriteString(fmt.Sprintf("   Estimated Time: %s | Confidence: %.1f%%\n", suggestion.EstimatedTime, suggestion.Confidence*100))
		if len(suggestion.Commands) > 0 {
			content.WriteString(fmt.Sprintf("   Commands: %s\n", strings.Join(suggestion.Commands, ", ")))
		}
		content.WriteString("\n")
		count++
	}

	return content.String()
}

func (c *CLI) displayConflicts(conflicts *intelligence.ConflictAnalysis, severity string, autoFix, dryRun bool) error {
	var content strings.Builder

	content.WriteString(utils.FormatHeader("System Conflicts Analysis"))
	content.WriteString(fmt.Sprintf("Analyzed: %s\n", conflicts.AnalyzedAt.Format("2006-01-02 15:04:05")))
	content.WriteString(fmt.Sprintf("Total Conflicts: %d\n", conflicts.TotalConflicts))
	
	// Severity breakdown
	content.WriteString("Severity Breakdown:\n")
	for sev, count := range conflicts.SeverityBreakdown {
		if count > 0 {
			content.WriteString(fmt.Sprintf("  %s: %d\n", strings.Title(sev), count))
		}
	}
	content.WriteString(utils.FormatDivider())

	if conflicts.TotalConflicts == 0 {
		content.WriteString("✅ No conflicts detected in your system!\n")
		fmt.Print(content.String())
		return nil
	}

	// Display conflicts by type
	if len(conflicts.PackageConflicts) > 0 {
		content.WriteString(c.formatPackageConflicts(conflicts.PackageConflicts, severity))
	}
	if len(conflicts.ServiceConflicts) > 0 {
		content.WriteString(c.formatServiceConflicts(conflicts.ServiceConflicts, severity))
	}
	if len(conflicts.PortConflicts) > 0 {
		content.WriteString(c.formatPortConflicts(conflicts.PortConflicts, severity))
	}
	if len(conflicts.ResourceConflicts) > 0 {
		content.WriteString(c.formatResourceConflicts(conflicts.ResourceConflicts, severity))
	}

	fmt.Print(content.String())
	return nil
}

func (c *CLI) formatPackageConflicts(conflicts []intelligence.PackageConflict, severity string) string {
	var content strings.Builder
	
	content.WriteString(utils.FormatSubHeader("Package Conflicts"))
	
	for _, conflict := range conflicts {
		if severity != "" && conflict.Severity != severity {
			continue
		}

		content.WriteString(fmt.Sprintf("⚠️  %s vs %s (%s)\n", conflict.Package1, conflict.Package2, conflict.Severity))
		content.WriteString(fmt.Sprintf("   Type: %s\n", conflict.ConflictType))
		content.WriteString(fmt.Sprintf("   %s\n", conflict.Description))
		if conflict.AutoResolvable {
			content.WriteString("   ✅ Auto-resolvable\n")
		}
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) formatServiceConflicts(conflicts []intelligence.ServiceConflict, severity string) string {
	var content strings.Builder
	
	content.WriteString(utils.FormatSubHeader("Service Conflicts"))
	
	for _, conflict := range conflicts {
		if severity != "" && conflict.Severity != severity {
			continue
		}

		content.WriteString(fmt.Sprintf("🔌 %s vs %s (%s)\n", conflict.Service1, conflict.Service2, conflict.Severity))
		content.WriteString(fmt.Sprintf("   Type: %s\n", conflict.ConflictType))
		content.WriteString(fmt.Sprintf("   %s\n", conflict.ConflictReason))
		if len(conflict.AffectedPorts) > 0 {
			content.WriteString(fmt.Sprintf("   Ports: %v\n", conflict.AffectedPorts))
		}
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) formatPortConflicts(conflicts []intelligence.PortConflict, severity string) string {
	var content strings.Builder
	
	content.WriteString(utils.FormatSubHeader("Port Conflicts"))
	
	for _, conflict := range conflicts {
		if severity != "" && conflict.Severity != severity {
			continue
		}

		content.WriteString(fmt.Sprintf("🔌 Port %d (%s) (%s)\n", conflict.Port, conflict.Protocol, conflict.Severity))
		content.WriteString(fmt.Sprintf("   Services: %s\n", strings.Join(conflict.ConflictingServices, ", ")))
		content.WriteString(fmt.Sprintf("   %s\n", conflict.Description))
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) formatResourceConflicts(conflicts []intelligence.ResourceConflict, severity string) string {
	var content strings.Builder
	
	content.WriteString(utils.FormatSubHeader("Resource Conflicts"))
	
	for _, conflict := range conflicts {
		if severity != "" && conflict.Severity != severity {
			continue
		}

		content.WriteString(fmt.Sprintf("💾 %s (%s) (%s)\n", conflict.ResourceType, conflict.ResourcePath, conflict.Severity))
		content.WriteString(fmt.Sprintf("   %s\n", conflict.Description))
		if len(conflict.ConflictingProcesses) > 0 {
			content.WriteString(fmt.Sprintf("   Processes: %s\n", strings.Join(conflict.ConflictingProcesses, ", ")))
		}
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) displayDependencies(dependencies *intelligence.DependencyAnalysis, showGraph bool, package string, depth int, format string) error {
	var content strings.Builder

	content.WriteString(utils.FormatHeader("Dependency Analysis"))
	content.WriteString(fmt.Sprintf("Total Nodes: %d\n", dependencies.Graph.TotalNodes))
	content.WriteString(fmt.Sprintf("Total Edges: %d\n", dependencies.Graph.TotalEdges))
	content.WriteString(fmt.Sprintf("Complexity Score: %.1f\n", dependencies.Graph.ComplexityScore))
	content.WriteString(fmt.Sprintf("Max Depth: %d\n", dependencies.Graph.MaxDepth))
	content.WriteString(fmt.Sprintf("Average Depth: %.1f\n", dependencies.Graph.AverageDepth))
	content.WriteString(utils.FormatDivider())

	// Summary statistics
	content.WriteString(utils.FormatSubHeader("Summary"))
	content.WriteString(utils.FormatKeyValue("Root Nodes", strconv.Itoa(len(dependencies.Graph.RootNodes))))
	content.WriteString(utils.FormatKeyValue("Leaf Nodes", strconv.Itoa(len(dependencies.Graph.LeafNodes))))
	content.WriteString(utils.FormatKeyValue("Orphaned Nodes", strconv.Itoa(len(dependencies.Graph.OrphanedNodes))))
	content.WriteString(utils.FormatKeyValue("Circular Dependencies", strconv.Itoa(len(dependencies.Graph.CircularDeps))))
	content.WriteString(utils.FormatKeyValue("Critical Paths", strconv.Itoa(len(dependencies.Graph.CriticalPaths))))

	// Show circular dependencies if any
	if len(dependencies.Graph.CircularDeps) > 0 {
		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Circular Dependencies"))
		for i, cycle := range dependencies.Graph.CircularDeps {
			if i >= 5 { // Limit to first 5
				break
			}
			content.WriteString(fmt.Sprintf("🔄 Cycle %d (%s severity):\n", i+1, cycle.Severity))
			content.WriteString(fmt.Sprintf("   %s\n", strings.Join(cycle.Cycle, " → ")))
			content.WriteString(fmt.Sprintf("   Length: %d nodes\n", cycle.Length))
			content.WriteString("\n")
		}
	}

	// Show critical paths
	if len(dependencies.Graph.CriticalPaths) > 0 {
		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Critical Paths"))
		for i, path := range dependencies.Graph.CriticalPaths {
			if i >= 3 { // Limit to first 3
				break
			}
			content.WriteString(fmt.Sprintf("🎯 Critical Path %d (score: %.1f):\n", i+1, path.CriticalityScore))
			content.WriteString(fmt.Sprintf("   %s\n", path.Description))
			content.WriteString(fmt.Sprintf("   Length: %d nodes\n", path.Length))
			content.WriteString("\n")
		}
	}

	// Show orphaned nodes
	if len(dependencies.Graph.OrphanedNodes) > 0 {
		content.WriteString(utils.FormatDivider())
		content.WriteString(utils.FormatSubHeader("Orphaned Nodes"))
		content.WriteString("These nodes have no dependencies or dependents and can potentially be removed:\n")
		for i, node := range dependencies.Graph.OrphanedNodes {
			if i >= 10 { // Limit to first 10
				content.WriteString(fmt.Sprintf("... and %d more\n", len(dependencies.Graph.OrphanedNodes)-10))
				break
			}
			content.WriteString(fmt.Sprintf("  • %s\n", node))
		}
	}

	fmt.Print(content.String())
	return nil
}

func (c *CLI) displayRecommendations(recommendations *intelligence.RecommendationSet, category, priority string, interactive, apply bool) error {
	var content strings.Builder

	content.WriteString(utils.FormatHeader("AI-Powered Recommendations"))
	content.WriteString(fmt.Sprintf("Generated: %s\n", recommendations.GeneratedAt.Format("2006-01-02 15:04:05")))
	content.WriteString(fmt.Sprintf("Total Recommendations: %d\n", recommendations.TotalRecommendations))
	content.WriteString(fmt.Sprintf("Overall Confidence: %.1f%%\n", recommendations.Confidence*100))
	content.WriteString(fmt.Sprintf("Estimated Impact: %s\n", recommendations.EstimatedImpact))
	content.WriteString(fmt.Sprintf("Time to Implement: %s\n", recommendations.TimeToImplement))
	content.WriteString(utils.FormatDivider())

	// Priority breakdown
	content.WriteString(utils.FormatSubHeader("Priority Breakdown"))
	for priority, count := range recommendations.PriorityBreakdown {
		if count > 0 {
			content.WriteString(utils.FormatKeyValue(strings.Title(priority), strconv.Itoa(count)))
		}
	}

	// Category breakdown
	content.WriteString(utils.FormatDivider())
	content.WriteString(utils.FormatSubHeader("Category Breakdown"))
	for category, count := range recommendations.CategoryBreakdown {
		if count > 0 {
			content.WriteString(utils.FormatKeyValue(strings.Title(category), strconv.Itoa(count)))
		}
	}

	// Show recommendations by category
	if category == "" || category == "optimization" {
		content.WriteString(c.formatSystemOptimizations(recommendations.SystemOptimizations, priority))
	}
	if category == "" || category == "security" {
		content.WriteString(c.formatSecurityRecommendations(recommendations.SecurityRecommendations, priority))
	}
	if category == "" || category == "performance" {
		content.WriteString(c.formatPerformanceRecommendations(recommendations.PerformanceRecommendations, priority))
	}

	fmt.Print(content.String())
	return nil
}

func (c *CLI) formatSystemOptimizations(optimizations []intelligence.SystemRecommendation, priority string) string {
	var content strings.Builder
	
	if len(optimizations) == 0 {
		return ""
	}

	content.WriteString(utils.FormatDivider())
	content.WriteString(utils.FormatSubHeader("System Optimizations"))
	
	for _, opt := range optimizations {
		if priority != "" && opt.Priority != priority {
			continue
		}

		content.WriteString(fmt.Sprintf("🔧 %s (%s priority)\n", opt.Title, opt.Priority))
		content.WriteString(fmt.Sprintf("   %s\n", opt.Description))
		content.WriteString(fmt.Sprintf("   Category: %s | Confidence: %.1f%%\n", opt.Category, opt.Confidence*100))
		content.WriteString(fmt.Sprintf("   Estimated Time: %s | Skill Level: %s\n", opt.EstimatedTime, opt.RequiredSkill))
		
		if len(opt.Benefits) > 0 {
			content.WriteString(fmt.Sprintf("   Benefits: %s\n", strings.Join(opt.Benefits, ", ")))
		}
		
		if len(opt.Actions) > 0 && len(opt.Actions) <= 3 { // Show actions if not too many
			content.WriteString("   Actions:\n")
			for _, action := range opt.Actions {
				content.WriteString(fmt.Sprintf("     %d. %s\n", action.StepNumber, action.Description))
				if action.Command != "" {
					content.WriteString(fmt.Sprintf("        Command: %s\n", action.Command))
				}
			}
		}
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) formatSecurityRecommendations(recommendations []intelligence.SecurityRecommendation, priority string) string {
	var content strings.Builder
	
	if len(recommendations) == 0 {
		return ""
	}

	content.WriteString(utils.FormatDivider())
	content.WriteString(utils.FormatSubHeader("Security Recommendations"))
	
	for _, rec := range recommendations {
		if priority != "" && rec.Severity != priority {
			continue
		}

		severityIcon := "🔒"
		switch rec.Severity {
		case "critical":
			severityIcon = "🚨"
		case "high":
			severityIcon = "⚠️"
		case "medium":
			severityIcon = "⚡"
		}

		content.WriteString(fmt.Sprintf("%s %s (%s severity)\n", severityIcon, rec.Title, rec.Severity))
		content.WriteString(fmt.Sprintf("   %s\n", rec.Description))
		content.WriteString(fmt.Sprintf("   Domain: %s | Confidence: %.1f%%\n", rec.SecurityDomain, rec.Confidence*100))
		content.WriteString(fmt.Sprintf("   Estimated Time: %s | Skill Level: %s\n", rec.EstimatedTime, rec.RequiredSkill))
		content.WriteString("\n")
	}

	return content.String()
}

func (c *CLI) formatPerformanceRecommendations(recommendations []intelligence.PerformanceRecommendation, priority string) string {
	var content strings.Builder
	
	if len(recommendations) == 0 {
		return ""
	}

	content.WriteString(utils.FormatDivider())
	content.WriteString(utils.FormatSubHeader("Performance Recommendations"))
	
	for _, rec := range recommendations {
		if priority != "" && rec.Priority != priority {
			continue
		}

		content.WriteString(fmt.Sprintf("🚀 %s (%s priority)\n", rec.Title, rec.Priority))
		content.WriteString(fmt.Sprintf("   %s\n", rec.Description))
		content.WriteString(fmt.Sprintf("   Area: %s | Confidence: %.1f%%\n", rec.PerformanceArea, rec.Confidence*100))
		content.WriteString(fmt.Sprintf("   Estimated Time: %s | Reversible: %t\n", rec.EstimatedTime, rec.Reversible))
		
		if len(rec.ExpectedGains) > 0 {
			content.WriteString("   Expected Gains:\n")
			for _, gain := range rec.ExpectedGains {
				content.WriteString(fmt.Sprintf("     • %s: %s (%.1f%% confidence)\n", gain.Metric, gain.ExpectedChange, gain.Confidence*100))
			}
		}
		content.WriteString("\n")
	}

	return content.String()
}

