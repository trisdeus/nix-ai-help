#!/bin/bash

# NixAI System Info Plugin - CLI Integration Script
# This provides system monitoring capabilities through nixai ask commands

set -e

PLUGIN_NAME="system-info"
PLUGIN_VERSION="1.0.0"

show_help() {
    cat << EOF
NixAI System Info Plugin v${PLUGIN_VERSION}

USAGE:
    nixai-system-info <operation> [options]

OPERATIONS:
    get-info        Get basic system information
    get-memory      Get memory usage details
    get-cpu         Get CPU information  
    get-disk        Get disk usage information
    health-check    Perform system health check
    get-processes   Get top processes
    monitor         Start interactive monitoring
    help            Show this help

EXAMPLES:
    nixai-system-info get-info
    nixai-system-info health-check
    nixai-system-info monitor

INTEGRATION WITH NIXAI:
    # Ask AI to analyze system health
    nixai ask "analyze my system health" --context-file <(nixai-system-info health-check)
    
    # Get AI recommendations for performance
    nixai ask "suggest performance improvements" --context-file <(nixai-system-info get-info && nixai-system-info get-processes)
    
    # Troubleshoot memory issues  
    nixai ask "help diagnose memory issues" --context-file <(nixai-system-info get-memory)

EOF
}

get_system_info() {
    echo "=== System Information ==="
    echo "Hostname: $(hostname)"
    echo "OS: $(uname -s)"
    echo "Kernel: $(uname -r)"
    echo "Architecture: $(uname -m)"
    echo "CPU Cores: $(nproc)"
    echo "Uptime: $(uptime -p)"
    echo "Load Average: $(uptime | sed 's/.*load average: //')"
    echo "Timestamp: $(date --iso-8601=seconds)"
}

get_memory_info() {
    echo "=== Memory Information ==="
    echo "Memory Usage:"
    free -h
    echo ""
    echo "Memory Details:"
    echo "Total RAM: $(free -h | awk '/^Mem:/ {print $2}')"
    echo "Used RAM: $(free -h | awk '/^Mem:/ {print $3}')"
    echo "Available RAM: $(free -h | awk '/^Mem:/ {print $7}')"
    echo "Memory Usage %: $(free | awk '/^Mem:/ {printf "%.1f", $3/$2 * 100.0}')"
    echo "Timestamp: $(date --iso-8601=seconds)"
}

get_cpu_info() {
    echo "=== CPU Information ==="
    echo "CPU Model: $(lscpu | grep 'Model name' | sed 's/Model name: *//')"
    echo "CPU Cores: $(nproc)"
    echo "CPU Architecture: $(lscpu | grep 'Architecture' | sed 's/Architecture: *//')"
    echo "CPU Frequency: $(lscpu | grep 'CPU MHz' | sed 's/CPU MHz: *//')MHz"
    echo ""
    echo "CPU Usage (1 minute average):"
    top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/" | awk '{print "CPU Idle: " $1 "%"; print "CPU Used: " (100 - $1) "%"}'
    echo "Timestamp: $(date --iso-8601=seconds)"
}

get_disk_info() {
    echo "=== Disk Information ==="
    echo "Disk Usage:"
    df -h | grep -vE '^Filesystem|tmpfs|cdrom'
    echo ""
    echo "Root Filesystem:"
    df -h / | tail -1 | awk '{print "Size: " $2 ", Used: " $3 ", Available: " $4 ", Usage: " $5}'
    echo "Timestamp: $(date --iso-8601=seconds)"
}

health_check() {
    echo "=== System Health Check ==="
    
    # Memory check
    MEMORY_USAGE=$(free | awk '/^Mem:/ {printf "%.1f", $3/$2 * 100.0}')
    if (( $(echo "$MEMORY_USAGE > 90" | bc -l) )); then
        echo "❌ CRITICAL: Memory usage is ${MEMORY_USAGE}% (>90%)"
    elif (( $(echo "$MEMORY_USAGE > 80" | bc -l) )); then
        echo "⚠️  WARNING: Memory usage is ${MEMORY_USAGE}% (>80%)"
    else
        echo "✅ GOOD: Memory usage is ${MEMORY_USAGE}%"
    fi
    
    # Disk check
    DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    if [ "$DISK_USAGE" -gt 95 ]; then
        echo "❌ CRITICAL: Root disk usage is ${DISK_USAGE}% (>95%)"
    elif [ "$DISK_USAGE" -gt 85 ]; then
        echo "⚠️  WARNING: Root disk usage is ${DISK_USAGE}% (>85%)"
    else
        echo "✅ GOOD: Root disk usage is ${DISK_USAGE}%"
    fi
    
    # Load average check
    LOAD_1MIN=$(uptime | awk -F'load average:' '{print $2}' | awk -F',' '{print $1}' | xargs)
    CPU_CORES=$(nproc)
    LOAD_PER_CORE=$(echo "scale=2; $LOAD_1MIN / $CPU_CORES" | bc)
    
    if (( $(echo "$LOAD_PER_CORE > 2.0" | bc -l) )); then
        echo "❌ CRITICAL: Load average is ${LOAD_1MIN} (${LOAD_PER_CORE} per core, >2.0)"
    elif (( $(echo "$LOAD_PER_CORE > 1.0" | bc -l) )); then
        echo "⚠️  WARNING: Load average is ${LOAD_1MIN} (${LOAD_PER_CORE} per core, >1.0)"
    else
        echo "✅ GOOD: Load average is ${LOAD_1MIN} (${LOAD_PER_CORE} per core)"
    fi
    
    # Service check (basic)
    echo ""
    echo "Critical Services Status:"
    for service in sshd systemd-resolved NetworkManager; do
        if systemctl is-active --quiet "$service" 2>/dev/null; then
            echo "✅ $service: running"
        else
            echo "⚠️  $service: not running or not available"
        fi
    done
    
    echo ""
    echo "Overall Status: $(date --iso-8601=seconds)"
}

get_processes() {
    echo "=== Top Processes ==="
    echo "Top 10 processes by CPU usage:"
    ps aux --sort=-pcpu | head -11
    echo ""
    echo "Top 10 processes by Memory usage:"
    ps aux --sort=-rss | head -11
    echo ""
    echo "Timestamp: $(date --iso-8601=seconds)"
}

start_monitor() {
    echo "=== System Monitor (Press Ctrl+C to stop) ==="
    while true; do
        clear
        echo "NixAI System Monitor - $(date)"
        echo "Press Ctrl+C to exit"
        echo ""
        
        # Quick health summary
        MEMORY_USAGE=$(free | awk '/^Mem:/ {printf "%.1f", $3/$2 * 100.0}')
        DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
        LOAD_1MIN=$(uptime | awk -F'load average:' '{print $2}' | awk -F',' '{print $1}' | xargs)
        
        echo "📊 Quick Health Summary:"
        echo "   Memory: ${MEMORY_USAGE}%"
        echo "   Disk:   ${DISK_USAGE}%"
        echo "   Load:   ${LOAD_1MIN}"
        echo ""
        
        # Top processes
        echo "🔄 Top Processes (CPU):"
        ps aux --sort=-pcpu | head -6 | tail -5 | awk '{printf "   %-12s %5s%% %s\n", $11, $3, $1}'
        
        sleep 5
    done
}

# Main command processing
case "${1:-help}" in
    "get-info")
        get_system_info
        ;;
    "get-memory")
        get_memory_info
        ;;
    "get-cpu")
        get_cpu_info
        ;;
    "get-disk")
        get_disk_info
        ;;
    "health-check")
        health_check
        ;;
    "get-processes")
        get_processes
        ;;
    "monitor")
        start_monitor
        ;;
    "help"|"-h"|"--help")
        show_help
        ;;
    *)
        echo "Unknown operation: $1"
        echo "Use 'nixai-system-info help' for usage information"
        exit 1
        ;;
esac